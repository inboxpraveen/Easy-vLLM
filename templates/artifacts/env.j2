# Generated by Easy-vLLM
# Adjust these values then run `docker compose up -d`.

# --- Server ---
VLLM_PORT=8000

# --- GPU ---
GPU_COUNT={{ gpu_count }}

# --- Hugging Face ---
{%- if is_private_hf_model %}
# Required: this model is gated. Get a token at https://huggingface.co/settings/tokens
HF_TOKEN=
{%- else %}
# Optional: only set this if you'll be loading gated models.
HF_TOKEN=
{%- endif %}
HF_CACHE_DIR=~/.cache/huggingface

# --- Local models ---
LOCAL_MODEL_DIR=./models

# --- vLLM image / runtime ---
# Set to 1 if you're on an older NVIDIA driver that needs CUDA compatibility libs.
VLLM_ENABLE_CUDA_COMPATIBILITY=0
{%- if api_key_required %}

# --- API auth ---
# Clients must send `Authorization: Bearer <this value>`.
VLLM_API_KEY=change-me-{{ random_token }}
{%- endif %}

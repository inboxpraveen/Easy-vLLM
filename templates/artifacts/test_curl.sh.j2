#!/usr/bin/env bash
# Generated by Easy-vLLM.
# Test your deployment with a simple chat completion call.
set -euo pipefail

BASE_URL="${VLLM_BASE_URL:-http://localhost:8000/v1}"
MODEL="${SERVED_MODEL_NAME:-{{ served_model_name }}}"
{% if api_key_required %}AUTH=(-H "Authorization: Bearer ${VLLM_API_KEY:-change-me}"){% else %}AUTH=(){% endif %}

curl -sS "${BASE_URL}/chat/completions" \
  -H "Content-Type: application/json" \
  "${AUTH[@]}" \
  -d '{
    "model": "'"${MODEL}"'",
    "messages": [
      {"role": "user", "content": "Say hello in one sentence."}
    ],
    "temperature": 0.2,
    "max_tokens": 64
  }' | jq .
